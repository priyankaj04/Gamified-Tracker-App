PORT=3000
NODE_ENV=development

# Supabase REST API client (used by the running server)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (used only by knex migrations)
# Get this from Supabase → Project Settings → Database → Connection string (URI)
# If the direct host fails on a free-tier IPv6 issue, use the pooler URL instead:
#   postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
